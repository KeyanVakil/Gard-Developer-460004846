@model GardPortal.ViewModels.VesselListViewModel
@{
    ViewData["Title"] = "Vessels";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-ship me-2 text-primary"></i>Vessel Registry</h1>
        <p class="text-muted mb-0">@Model.TotalCount vessels registered</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Register Vessel
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th><a asp-action="Index" asp-route-sortBy="name" asp-route-page="1" class="text-white text-decoration-none">Name <i class="bi bi-arrow-down-up ms-1"></i></a></th>
                        <th><a asp-action="Index" asp-route-sortBy="imonumber" asp-route-page="1" class="text-white text-decoration-none">IMO Number</a></th>
                        <th><a asp-action="Index" asp-route-sortBy="vesseltype" asp-route-page="1" class="text-white text-decoration-none">Type</a></th>
                        <th><a asp-action="Index" asp-route-sortBy="flagstate" asp-route-page="1" class="text-white text-decoration-none">Flag State</a></th>
                        <th><a asp-action="Index" asp-route-sortBy="grosstonnage" asp-route-page="1" class="text-white text-decoration-none">GT</a></th>
                        <th><a asp-action="Index" asp-route-sortBy="yearbuilt" asp-route-page="1" class="text-white text-decoration-none">Built</a></th>
                        <th>Policies</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vessel in Model.Vessels)
                    {
                        <tr>
                            <td class="fw-semibold">
                                <a asp-action="Details" asp-route-id="@vessel.Id" class="text-decoration-none">@vessel.Name</a>
                            </td>
                            <td class="font-monospace text-muted">@vessel.ImoNumber</td>
                            <td><span class="badge bg-secondary">@vessel.VesselType</span></td>
                            <td>@vessel.FlagState</td>
                            <td>@vessel.GrossTonnage.ToString("N0")</td>
                            <td>@vessel.YearBuilt</td>
                            <td>
                                <span class="badge bg-primary">@vessel.Policies.Count(p => p.Status == GardPortal.Models.PolicyStatus.Active) active</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@vessel.Id" class="btn btn-sm btn-outline-secondary me-1">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@vessel.Id" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@vessel.Id" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-sortBy="@Model.SortBy">@i</a>
                </li>
            }
        </ul>
    </nav>
}
