@model GardPortal.ViewModels.PolicyFormViewModel
@using GardPortal.Models
@{
    ViewData["Title"] = "New Policy";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item"><a asp-action="Index">Policies</a></li>
            <li class="breadcrumb-item active">New Policy</li>
        </ol>
    </nav>
    <h1 class="h3"><i class="bi bi-plus-circle me-2 text-primary"></i>Create New Policy</h1>
</div>

<div class="row">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post" id="policyForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="VesselId" class="form-label fw-semibold">Vessel *</label>
                        <select asp-for="VesselId" class="form-select" asp-items="Model.Vessels" id="vesselSelect">
                            <option value="">Select vessel...</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CoverageType" class="form-label fw-semibold">Coverage Type *</label>
                        <select asp-for="CoverageType" class="form-select" asp-items="Html.GetEnumSelectList<CoverageType>()" id="coverageSelect">
                            <option value="">Select coverage...</option>
                        </select>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label fw-semibold">Start Date *</label>
                            <input asp-for="StartDate" class="form-control" type="date" id="startDate" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-semibold">End Date *</label>
                            <input asp-for="EndDate" class="form-control" type="date" id="endDate" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="InsuredValue" class="form-label fw-semibold">Insured Value (USD) *</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="InsuredValue" class="form-control" type="number" step="1000" min="1" id="insuredValue" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-success">
                            <i class="bi bi-calculator me-1"></i>Estimated Annual Premium
                        </label>
                        <div class="form-control bg-light text-success fw-bold" id="premiumPreview">
                            Select vessel and coverage to see premium estimate
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label fw-semibold">Notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Create Policy
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card border-info">
            <div class="card-header bg-info text-white">
                <h6 class="mb-0"><i class="bi bi-table me-2"></i>Premium Rate Table</h6>
            </div>
            <div class="card-body">
                <p class="small text-muted mb-2">Premium = Insured Value × Base Rate × Vessel Factor</p>
                <table class="table table-sm small mb-3">
                    <thead><tr><th>Coverage</th><th>Base Rate</th></tr></thead>
                    <tbody>
                        <tr><td>P&amp;I</td><td>0.25%</td></tr>
                        <tr><td>H&amp;M</td><td>0.40%</td></tr>
                        <tr><td>Cargo</td><td>0.15%</td></tr>
                        <tr><td>Loss of Hire</td><td>0.20%</td></tr>
                    </tbody>
                </table>
                <table class="table table-sm small mb-0">
                    <thead><tr><th>Vessel Type</th><th>Factor</th></tr></thead>
                    <tbody>
                        <tr><td>Bulk Carrier</td><td>1.00</td></tr>
                        <tr><td>Container Ship</td><td>1.10</td></tr>
                        <tr><td>RoRo</td><td>1.05</td></tr>
                        <tr><td>General Cargo</td><td>0.95</td></tr>
                        <tr><td>Tanker</td><td>1.30</td></tr>
                        <tr><td>Offshore</td><td>1.40</td></tr>
                        <tr><td>Passenger Ferry</td><td>1.20</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScripts")
    <script>
        const baseRates = { '0': 0.0025, '1': 0.0040, '2': 0.0015, '3': 0.0020 };
        const vesselFactors = { '0': 1.0, '1': 1.3, '2': 1.1, '3': 1.05, '4': 0.95, '5': 1.4, '6': 1.2 };

        // We store vessel type per vessel id via data attributes embedded in select
        const vesselTypes = {};
        @foreach (var v in (await Html.PartialAsync("_VesselTypesJson")).ToString().Split('\n'))
        { }

        function updatePremium() {
            const insuredValue = parseFloat(document.getElementById('insuredValue').value) || 0;
            const coverageVal  = document.getElementById('coverageSelect').value;
            const preview      = document.getElementById('premiumPreview');

            if (insuredValue > 0 && coverageVal !== '') {
                const rate    = baseRates[coverageVal] ?? 0.0025;
                // Simple estimate without vessel factor (exact calc happens server-side)
                const premium = insuredValue * rate;
                preview.textContent = '~$' + premium.toLocaleString('en-US', { maximumFractionDigits: 0 }) + ' (est., before vessel factor)';
            } else {
                preview.textContent = 'Select vessel and coverage to see premium estimate';
            }
        }

        document.getElementById('insuredValue').addEventListener('input', updatePremium);
        document.getElementById('coverageSelect').addEventListener('change', updatePremium);
    </script>
}
