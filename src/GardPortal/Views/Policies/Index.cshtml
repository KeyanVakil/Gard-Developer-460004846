@model List<GardPortal.Models.Policy>
@using GardPortal.Models
@{
    ViewData["Title"] = "Policies";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentStatus       = ViewBag.Status as PolicyStatus?;
    var currentCoverageType = ViewBag.CoverageType as CoverageType?;
    var currentVesselName   = ViewBag.VesselName as string;
    int totalCount          = ViewBag.TotalCount;
    int page                = ViewBag.Page;
    int totalPages          = ViewBag.TotalPages;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-file-earmark-text me-2 text-primary"></i>Policy Administration</h1>
        <p class="text-muted mb-0">@totalCount policies</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>New Policy
    </a>
</div>

<form method="get" class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    @foreach (var s in Enum.GetValues<PolicyStatus>())
                    {
                        <option value="@s" selected="@(currentStatus == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Coverage Type</label>
                <select name="coverageType" class="form-select form-select-sm">
                    <option value="">All Types</option>
                    @foreach (var c in Enum.GetValues<CoverageType>())
                    {
                        <option value="@c" selected="@(currentCoverageType == c)">@c</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Vessel Name</label>
                <input type="text" name="vesselName" value="@currentVesselName" class="form-control form-control-sm" placeholder="Search vessel..." />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-primary btn-sm w-100">
                    <i class="bi bi-search me-1"></i>Filter
                </button>
            </div>
        </div>
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Policy Number</th>
                        <th>Vessel</th>
                        <th>Coverage</th>
                        <th>Status</th>
                        <th>Insured Value</th>
                        <th>Premium</th>
                        <th>Expires</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var policy in Model)
                    {
                        <tr>
                            <td class="font-monospace fw-semibold">
                                <a asp-action="Details" asp-route-id="@policy.Id" class="text-decoration-none">@policy.PolicyNumber</a>
                            </td>
                            <td>
                                <a asp-controller="Vessels" asp-action="Details" asp-route-id="@policy.VesselId" class="text-decoration-none text-muted">
                                    @policy.Vessel?.Name
                                </a>
                            </td>
                            <td class="small">@policy.CoverageType</td>
                            <td><span class="badge status-@policy.Status.ToString().ToLower()">@policy.Status</span></td>
                            <td>@policy.InsuredValue.ToString("C0")</td>
                            <td>@policy.AnnualPremium.ToString("C0")</td>
                            <td class="small text-muted">@policy.EndDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@policy.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-status="@currentStatus"
                       asp-route-coverageType="@currentCoverageType"
                       asp-route-vesselName="@currentVesselName">@i</a>
                </li>
            }
        </ul>
    </nav>
}
