@model GardPortal.ViewModels.ClaimDetailViewModel
@using GardPortal.Models
@{
    ViewData["Title"] = Model.Claim.ClaimNumber;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index">Claims</a></li>
                <li class="breadcrumb-item active">@Model.Claim.ClaimNumber</li>
            </ol>
        </nav>
        <h1 class="h3 mb-0">
            <i class="bi bi-exclamation-triangle me-2 text-danger"></i>@Model.Claim.ClaimNumber
            <span class="badge claim-@Model.Claim.Status.ToString().ToLower() ms-2 fs-6">@Model.Claim.Status</span>
        </h1>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Claim Details</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted">Policy</dt>
                    <dd class="col-sm-7">
                        <a asp-controller="Policies" asp-action="Details" asp-route-id="@Model.Claim.PolicyId">
                            @Model.Claim.Policy?.PolicyNumber
                        </a>
                    </dd>
                    <dt class="col-sm-5 text-muted">Vessel</dt>
                    <dd class="col-sm-7">@Model.Claim.Policy?.Vessel?.Name</dd>
                    <dt class="col-sm-5 text-muted">Category</dt>
                    <dd class="col-sm-7"><span class="badge bg-secondary">@Model.Claim.Category</span></dd>
                    <dt class="col-sm-5 text-muted">Incident Date</dt>
                    <dd class="col-sm-7">@Model.Claim.IncidentDate.ToString("dd MMM yyyy")</dd>
                    <dt class="col-sm-5 text-muted">Filed</dt>
                    <dd class="col-sm-7">@Model.Claim.CreatedAt.ToString("dd MMM yyyy")</dd>
                    <dt class="col-sm-5 text-muted">Estimated</dt>
                    <dd class="col-sm-7 fw-bold">@Model.Claim.EstimatedAmount.ToString("C0")</dd>
                    @if (Model.Claim.SettledAmount.HasValue)
                    {
                        <dt class="col-sm-5 text-muted">Settled</dt>
                        <dd class="col-sm-7 fw-bold text-success">@Model.Claim.SettledAmount.Value.ToString("C0")</dd>
                    }
                </dl>
                @if (!string.IsNullOrEmpty(Model.Claim.Description))
                {
                    <hr />
                    <p class="small mb-0"><strong>Description:</strong> @Model.Claim.Description</p>
                }
            </div>
        </div>

        @if (Model.NextStatuses.Any())
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-arrow-right-circle me-2"></i>Advance Status</h6>
                </div>
                <div class="card-body">
                    <form asp-action="Transition" method="post">
                        <input type="hidden" name="id" value="@Model.Claim.Id" />
                        <div class="mb-3">
                            <label class="form-label small">New Status</label>
                            <select name="newStatus" class="form-select form-select-sm">
                                @foreach (var s in Model.NextStatuses)
                                {
                                    <option value="@s.Value">@s.Text</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Notes</label>
                            <textarea name="notes" class="form-control form-control-sm" rows="2" placeholder="Optional notes..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-sm btn-outline-primary w-100">
                            <i class="bi bi-check2 me-1"></i>Update Status
                        </button>
                    </form>
                </div>
            </div>
        }

        @if (Model.Claim.Status == ClaimStatus.Approved)
        {
            <div class="card shadow-sm border-success">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0"><i class="bi bi-cash-coin me-2"></i>Settle Claim</h6>
                </div>
                <div class="card-body">
                    <form asp-action="Settle" method="post">
                        <input type="hidden" name="id" value="@Model.Claim.Id" />
                        <div class="mb-3">
                            <label class="form-label small">Settlement Amount (USD)</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">$</span>
                                <input type="number" name="settlementAmount" class="form-control"
                                    value="@Model.Claim.EstimatedAmount" step="100" min="1" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Settlement Notes</label>
                            <textarea name="notes" class="form-control form-control-sm" rows="2"></textarea>
                        </div>
                        <button type="submit" class="btn btn-sm btn-success w-100">
                            <i class="bi bi-check-circle me-1"></i>Settle Claim
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Status Timeline</h5>
            </div>
            <div class="card-body">
                @if (Model.Claim.History.Any())
                {
                    <div class="timeline">
                        @foreach (var entry in Model.Claim.History.OrderBy(h => h.ChangedAt))
                        {
                            <div class="timeline-item d-flex gap-3 mb-4">
                                <div class="timeline-marker">
                                    <div class="timeline-dot bg-primary rounded-circle d-flex align-items-center justify-content-center">
                                        <i class="bi bi-check text-white small"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            @if (entry.FromStatus == entry.ToStatus)
                                            {
                                                <span class="badge claim-@entry.ToStatus.ToString().ToLower()">@entry.ToStatus — Filed</span>
                                            }
                                            else
                                            {
                                                <span class="badge claim-@entry.FromStatus.ToString().ToLower() me-1">@entry.FromStatus</span>
                                                <i class="bi bi-arrow-right mx-1 text-muted"></i>
                                                <span class="badge claim-@entry.ToStatus.ToString().ToLower()">@entry.ToStatus</span>
                                            }
                                        </div>
                                        <small class="text-muted">@entry.ChangedAt.ToString("dd MMM yyyy HH:mm")</small>
                                    </div>
                                    @if (!string.IsNullOrEmpty(entry.Notes))
                                    {
                                        <p class="mb-0 mt-1 small text-muted">@entry.Notes</p>
                                    }
                                    <div class="small text-muted mt-1">by @entry.ChangedBy</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">No history available.</p>
                }
            </div>
        </div>
    </div>
</div>
