@model List<GardPortal.Models.Claim>
@using GardPortal.Models
@{
    ViewData["Title"] = "Claims";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentStatus   = ViewBag.Status as ClaimStatus?;
    var currentCategory = ViewBag.Category as ClaimCategory?;
    var currentFrom     = ViewBag.From as DateTime?;
    var currentTo       = ViewBag.To as DateTime?;
    int totalCount      = ViewBag.TotalCount;
    int page            = ViewBag.Page;
    int totalPages      = ViewBag.TotalPages;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-exclamation-triangle me-2 text-danger"></i>Claims Processing</h1>
        <p class="text-muted mb-0">@totalCount claims on record</p>
    </div>
    <a asp-action="Create" class="btn btn-danger">
        <i class="bi bi-plus-circle me-1"></i>File Claim
    </a>
</div>

<form method="get" class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var s in Enum.GetValues<ClaimStatus>())
                    {
                        <option value="@s" selected="@(currentStatus == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Category</label>
                <select name="category" class="form-select form-select-sm">
                    <option value="">All Categories</option>
                    @foreach (var c in Enum.GetValues<ClaimCategory>())
                    {
                        <option value="@c" selected="@(currentCategory == c)">@c</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">From</label>
                <input type="date" name="from" value="@currentFrom?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">To</label>
                <input type="date" name="to" value="@currentTo?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-primary btn-sm w-100">
                    <i class="bi bi-search me-1"></i>Filter
                </button>
            </div>
        </div>
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Claim #</th>
                        <th>Vessel</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Estimated</th>
                        <th>Settled</th>
                        <th>Incident Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var claim in Model)
                    {
                        <tr>
                            <td class="font-monospace fw-semibold">
                                <a asp-action="Details" asp-route-id="@claim.Id" class="text-decoration-none">@claim.ClaimNumber</a>
                            </td>
                            <td class="small text-muted">@claim.Policy?.Vessel?.Name</td>
                            <td><span class="badge bg-secondary">@claim.Category</span></td>
                            <td><span class="badge claim-@claim.Status.ToString().ToLower()">@claim.Status</span></td>
                            <td>@claim.EstimatedAmount.ToString("C0")</td>
                            <td>@(claim.SettledAmount.HasValue ? claim.SettledAmount.Value.ToString("C0") : "-")</td>
                            <td class="small text-muted">@claim.IncidentDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@claim.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-status="@currentStatus"
                       asp-route-category="@currentCategory">@i</a>
                </li>
            }
        </ul>
    </nav>
}
