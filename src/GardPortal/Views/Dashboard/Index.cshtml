@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-speedometer2 me-2 text-primary"></i>Portfolio Dashboard</h1>
        <p class="text-muted mb-0">Real-time portfolio analytics and risk monitoring</p>
    </div>
</div>

<div id="app">
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Loading dashboard...</p>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/dashboard/dist/main.js"></script>
}
